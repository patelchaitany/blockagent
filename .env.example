# ============================================================
# BlockAgent — Environment Variables
# ============================================================

# ── Required: AI Inference ──────────────────────────────────
# Venice AI (private, zero data retention):
VENICE_API_KEY=your-venice-api-key

# ── Required: RPC Endpoints ────────────────────────────────
BASE_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── Optional: Delegated Execution ──────────────────────────
# Only needed if you want the agent to execute trades via
# the ScopedDelegation contract. Analysis works without these.
#
# WALLET_PRIVATE_KEY=0x_agent_session_key (NOT your main wallet)
# UNISWAP_API_KEY=your-uniswap-api-key
# DELEGATION_CONTRACT=0x_deployed_scoped_delegation_address

# ── Optional: MEV Protection ──────────────────────────────
# Private RPC for mainnet transaction submission.
# Shields on-chain execution from mempool snipers / MEV bots.
# Flashbots Protect: https://rpc.flashbots.net
# MEV Blocker:       https://rpc.mevblocker.io
# PRIVATE_RPC_URL=https://rpc.flashbots.net

# ── Optional: Safety Tuning ────────────────────────────────
# Max percentage of portfolio the agent can recommend trading per action.
# Default is 10%. Increase if you want faster rebalancing.
# The ScopedDelegation contract enforces the hard ceiling regardless.
# MAX_TRADE_PERCENT=10

# ── Optional: Demo Mode ────────────────────────────────────
# Set to "true" for Railway/hosted deployment (returns sample responses)
# DEMO_MODE=true

# ── Optional: Status Network ───────────────────────────────
# STATUS_RPC_URL=https://public.sepolia.rpc.status.network
